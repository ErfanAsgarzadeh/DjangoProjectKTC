# ---------------------------------------------------------------
# KTCProject environment variables.
# Copy this file to `.env` and fill in real values for your machine.
#   cp .env.example .env
# `.env` is gitignored and must NEVER be committed.
# ---------------------------------------------------------------

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Set DB_ENGINE=sqlite to fall back to the old db.sqlite3 file (useful for emergencies).
DB_ENGINE=postgres

POSTGRES_DB=ktcproject
POSTGRES_USER=ktc_user
POSTGRES_PASSWORD=ktc_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
